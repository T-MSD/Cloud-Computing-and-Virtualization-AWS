#!/bin/bash
# AWS configuration for the CNV project.
#
# Copy this file to config.sh (which is gitignored) and fill in your values:
#   cp config.sh.example config.sh
#   nano config.sh
#
# Then load it before running Maven / Java:
#   source config.sh

# AWS region used by all resources
export AWS_DEFAULT_REGION=eu-north-1

# Account-level identifiers
export AWS_ACCOUNT_ID=<your 12-digit account id, top right of AWS console under your name>

# Programmatic access credentials (AWS Console -> Security credentials -> Create access key)
export AWS_ACCESS_KEY_ID=<your access key id, starts with AKIA...>
export AWS_SECRET_ACCESS_KEY=<your secret access key, long random string>

# EC2 SSH key pair
export AWS_KEYPAIR_NAME=mykeypair
export AWS_EC2_SSH_KEYPAR_PATH=/home/vagrant/mykeypair.pem

# Worker security group (the SG used by EC2 workers, not the LB)
export AWS_SECURITY_GROUP_ID=<sg-xxxxxxxxxxxxxxxxx>
export AWS_SECURITY_GROUP=launch-wizard-1

# Worker AMI (created from your golden image with WebServer + auto-start)
export AWS_AMI_ID=<ami-xxxxxxxxxxxxxxxxx>

# Worker instance type (optional; defaults to t3.micro for free tier)
# export AWS_INSTANCE_TYPE=t3.micro

# IAM Instance Profile attached to launched workers (optional but required
# if the WebServer inside the worker uses AWS services like DynamoDB).
# This is the IAM Role NAME — when you create a role via the EC2 console
# wizard, an Instance Profile with the same name is auto-created.
export AWS_INSTANCE_PROFILE=cnv-worker-role

# --- Lambda overflow (optional) ---------------------------------------------
# Lambda is used as an overflow valve for LIGHT requests when the worker
# pool is overloaded. One function per workload; set the ones you've deployed,
# leave the rest unset (those workloads then stay on the EC2 pool).
export AWS_LAMBDA_FRACTALS=JuliaFractals_Lambda
export AWS_LAMBDA_DNA=DNA_Genome_Lambda
export AWS_LAMBDA_GRAYSCOTT=Gray_Scott_Lambda
#
# Light requests (cost <= LAMBDA_MAX_COST) are eligible for Lambda.
# Heavy requests always stay on EC2 (Lambda's 15-min hard timeout makes
# it unsuitable). Default 10000.
export LAMBDA_MAX_COST=10000
#
# Workers' average CPU must be above this for Lambda to take traffic.
# Below the threshold the pool has capacity and Lambda is unused.
# Default 70.0.
export LAMBDA_CPU_THRESHOLD=80
#Proximity Values for each cache. Should be an integer number
export JULIA_FRACTALS_PROXIMITY=150000000
export GRAY_SCOTT_PROXIMITY=150000000
export DNA_PROXIMITY=500000
